root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

# C++ (Unreal Engine convention: tabs)
[*.{cpp,h,inl}]
indent_style = tab
indent_size = 4

# C# (Unreal Build Tool)
[*.cs]
indent_style = tab
indent_size = 4

# Config / Data
[*.{ini,json,uproject,uplugin}]
indent_style = tab
indent_size = 4
